{
  "expo": {
    "name": "KB Events",
    "slug": "kbapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kbevents.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.kbevents.app",
      "permissions": [
        "INTERNET"
      ],
      "versionCode": 7
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "owner": "forda",
    "extra": {
      "eas": {
        "projectId": "33aecfaa-8c54-48c0-83cc-53022a4f307a"
      }
    }
  }
}