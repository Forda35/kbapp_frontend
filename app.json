{
  "expo": {
    "name": "KB Events",
    "slug": "kbapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kbevents.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.kbevents.mobile",
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "8998c4c8-faf7-4bfb-b667-a305f1cc0f90"
      }
    },
    "owner": "forda"
  }
}
