{
  "expo": {
    "name": "KBApp",
    "slug": "kbapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kbapp.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Utilisé pour scanner les QR codes des billets"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.kbapp.mobile",
      "permissions": [
        "INTERNET",
        "RECEIVE_SMS",
        "READ_SMS"
      ]
    },
    "plugins": [
      "expo-screen-capture"
    ],
    "extra": {
      "eas": {
        "projectId": "8998c4c8-faf7-4bfb-b667-a305f1cc0f90"
      }
    }
  }
}